generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String   @id @default(uuid())
  fullName    String
  email       String   @unique
  password    String
  avatar      String   @default("")
  role        String   @default("ATTENDEE")
  createdAt   DateTime @default(now())

  createdEvents Event[]
  tickets       Ticket[]
  savedEvents   SavedEvent[]
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  icon  String
  color String
}

model Event {
  id               String   @id @default(uuid())
  title            String
  description      String
  shortDescription String
  category         String
  date             String
  time             String
  endTime          String?
  location         String
  address          String
  city             String
  price            Float    @default(0)
  maxPrice         Float?
  currency         String   @default("USD")
  image            String
  maxAttendees     Int      @default(100)
  isFeatured       Boolean  @default(false)
  tags             String   @default("[]")
  isFree           Boolean  @default(false)
  approvalStatus   String   @default("APPROVED")
  viewsCount       Int      @default(0)

  organizerName     String  @default("")
  organizerAvatar   String  @default("")
  organizerVerified Boolean @default(true)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  tickets     Ticket[]
  savedBy     SavedEvent[]
  ticketTypes TicketType[]

  createdAt DateTime @default(now())
}

model TicketType {
  id          String @id @default(uuid())
  eventId     String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  description String
  available   Int
  maxPerOrder Int    @default(10)
  tickets     Ticket[]
}

model Ticket {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  eventId      String
  event        Event      @relation(fields: [eventId], references: [id])
  ticketTypeId String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  purchaseDate DateTime   @default(now())
  status       String     @default("VALID")
  qrCode       String     @unique

  createdAt DateTime @default(now())
}

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}
